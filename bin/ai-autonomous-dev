#!/usr/bin/env bash
# ==============================================================================
# 🌀 AdventureForge - Autonomous AI Developer Loop Harness
# ==============================================================================
# Enforces indefinite execution of the AI development agent in YOLO mode.
# Press CTRL+C to safely exit the loop.
# ==============================================================================

PROMPT="You are the autonomous development agent for AdventureForge, a strictly typed, headless, deterministic text-adventure engine.

YOUR WORKSPACE IS IN: $(pwd)
DO NOT work in any temporary or scratch folders outside this directory. All work must be applied directly to this codebase.

CRITICAL: You are executed as a single, discrete cycle within an outer bash loop. You MUST NOT loop indefinitely, run sleep statements, or leave blocking background tasks running. Instead, perform exactly ONE execution cycle of Plan, Build, Verify, Playtest, and Evaluate, write your report, and exit cleanly so the outer loop can capture your work and launch the next cycle.

Core loop for this cycle:

1. PLAN
   * Inspect the current project files and the persistent plan in 'living_plan.md'.
   * Identify the highest-impact next task in the backlog.
   * Prioritize concrete game improvements and resolving real code/pack validation issues.
   * CHECK FEEDBACK: If the file 'feedback_consolidated.md' exists and has been updated since you last read it, review it. Incorporate the top priorities from the playtest digest into your task selection. This file is generated by a parallel blind playtest loop and contains player experience feedback — treat BLOCKING issues as high priority.

2. BUILD
   * Implement the selected feature, fix, test, or content expansion.
   * Keep changes scoped to what can be fully verified in this single cycle.
   * Keep the game playable at all times; avoid large untested rewrites.

3. VERIFY
   * Run the TypeScript compiler ('pnpm build') to ensure type safety.
   * Run the test suite ('pnpm test') to ensure no regressions are introduced.
   * Run the content autopilot validator ('pnpm autopilot') to check all game packs.

4. SANITY PLAYTEST (MANDATORY)
   * You MUST run at least one sanity playtest after making changes. This is non-negotiable.
   * Boot the game with the content pack(s) affected by your changes.
   * Walk through the changed area to verify: the game starts, the changes work as expected, nothing crashes or acts weird.
   * You can do this by running: npx tsx src/bin/playtest-session.ts --pack <pack_id> --persona explorer --max-steps 30
   * Alternatively, use the MCP server or direct API to do a quick targeted walkthrough.
   * If the sanity playtest reveals issues, fix them immediately before committing.

5. EVALUATE
   * Review the auto-playtest outcomes and validation reports generated by your tests, autopilot, and sanity playtest.
   * If any compiler error, test failure, or graph validator warning is reported, fix the issue immediately in this cycle! Do not commit broken code or warnings.

6. RECORD & EXIT
   * Update the 'living_plan.md' file with the latest cycle index, updated task status, learnings, and next priority items.
   * Output a summary matching the exact format below, and then exit the session immediately.

Output format for each cycle:

## Current Plan

* Main objective:
* Why this matters:
* Tasks:
* Risks:
* Feedback digest reviewed: yes/no (and any items incorporated)

## Work Completed

* Changes made:
* Files/systems touched:
* New content/features added:

## Sanity Playtest

* Pack tested:
* Steps taken:
* Game boots: yes/no
* Changes work as expected: yes/no
* Issues found:

## Playtest Notes

* What was tested:
* What worked:
* What felt bad/confusing:
* Bugs found:

## Next Iteration

* Highest-priority next task:
* Reason:
* Planned action:

This is the end of your single cycle. Terminate now."

# Verify execution command or that agy CLI is available
if [[ -z "${AI_AGENT_CMD:-}" ]]; then
  if ! command -v agy &> /dev/null; then
    echo "🔴 Error: The 'agy' (Antigravity) CLI tool could not be found."
    echo "Please make sure it is installed and present in your system PATH, or set AI_AGENT_CMD."
    exit 1
  fi
fi

CYCLE=1
FAILURES=0
MAX_FAILURES=3

echo "================================================================================"
echo "🚀 Starting Indefinite Autonomous AI Developer Loop Harness..."
echo "Press CTRL+C at any time to stop the loop."
echo "================================================================================"

while true; do
  echo ""
  echo "================================================================================"
  echo "🌀 RUNNING AUTONOMOUS CYCLE #$CYCLE"
  echo "================================================================================"
  
  # Run the agent and redirect output to capture semantic commit descriptions
  mkdir -p "$(dirname "$0")/../cache"
  AGENT_OUT="$(dirname "$0")/../cache/agent_output.log"
  set -o pipefail

  if [[ -n "${AI_AGENT_CMD:-}" ]]; then
    if [[ "$AI_AGENT_CMD" =~ --print$ || "$AI_AGENT_CMD" =~ -p$ || "$AI_AGENT_CMD" =~ --prompt$ ]]; then
      echo "🤖 Executing agent via: $AI_AGENT_CMD \"[PROMPT]\""
      eval "$AI_AGENT_CMD \"\$PROMPT\"" | tee "$AGENT_OUT"
      STATUS=$?
    else
      echo "🤖 Executing agent via: $AI_AGENT_CMD"
      echo "$PROMPT" | eval "$AI_AGENT_CMD" | tee "$AGENT_OUT"
      STATUS=$?
    fi
  else
    echo "🤖 Executing agent via 'agy'..."
    agy --dangerously-skip-permissions --print "$PROMPT" | tee "$AGENT_OUT"
    STATUS=$?
  fi
  
  if [ $STATUS -eq 0 ]; then
    FAILURES=0
    echo "🟢 Cycle #$CYCLE executed successfully."
    
    # Autonomous Git staging and commit
    if [[ -n $(git status --porcelain) ]]; then
      echo ""
      echo "💾 Staging and committing cycle #$CYCLE changes autonomously..."
      
      # Extract the first bullet point under Work Completed from the agent output log
      RAW_SUMMARY=$(grep -i -A 4 "## Work Completed" "$AGENT_OUT" | grep -E "^\s*[\*-]" | head -n 1 | sed 's/^[[:space:]]*[\*-][[:space:]]*//' | xargs)
      COMMIT_MSG=${RAW_SUMMARY:-"autonomous cycle #$CYCLE improvements"}

      git add -A
      git commit -m "chore(ai-dev): $COMMIT_MSG"
      echo "🟢 Committed successfully."

      # Push and merge to main
      CURRENT_BRANCH=$(git branch --show-current)
      echo "📤 Pushing branch '$CURRENT_BRANCH' to origin..."
      if git push origin "$CURRENT_BRANCH"; then
        if [[ "$CURRENT_BRANCH" != "main" ]]; then
          echo "🔄 Merging '$CURRENT_BRANCH' into main..."
          # Save current branch and ensure we switch back on error or exit
          if git checkout main; then
            if git pull origin main && git merge "$CURRENT_BRANCH" --no-edit && git push origin main; then
              echo "🟢 Successfully merged and pushed to main."
            else
              echo "🔴 Failed to pull, merge, or push main."
            fi
            # Always switch back to the starting branch
            git checkout "$CURRENT_BRANCH"
          else
            echo "🔴 Failed to checkout main."
          fi
        else
          echo "🟢 Successfully pushed main to origin."
        fi
      else
        echo "🔴 Failed to push current branch '$CURRENT_BRANCH' to origin."
      fi
    else
      echo ""
      echo "➖ No changes detected in cycle #$CYCLE. Skipping Git commit."
    fi
  else
    FAILURES=$((FAILURES + 1))
    echo "🔴 Cycle #$CYCLE failed with exit code $STATUS. (Failure $FAILURES of $MAX_FAILURES)"
    
    if [ $FAILURES -ge $MAX_FAILURES ]; then
      echo ""
      echo "🛑 CIRCUIT BREAKER TRIGGERED!"
      echo "The autonomous agent has failed consecutively $MAX_FAILURES times."
      echo "Halting the dev loop to protect tokens and prevent infinite crash loops."
      echo "Please inspect the error logs above and check the current state."
      echo "================================================================================"
      exit $STATUS
    fi
  fi
  
  # End of cycle, increment and sleep
  echo "================================================================================"
  echo "✅ Cycle #$CYCLE complete!"
  CYCLE=$((CYCLE + 1))
  
  echo "Sleeping for 10 seconds before booting next cycle... Press CTRL+C to exit."
  sleep 10
done
