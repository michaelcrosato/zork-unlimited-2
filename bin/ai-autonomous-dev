#!/usr/bin/env bash
# ==============================================================================
# 🌀 AdventureForge - Autonomous AI Developer Loop Harness
# ==============================================================================
# Enforces indefinite execution of the AI development agent in YOLO mode.
# Press CTRL+C to safely exit the loop.
# ==============================================================================

PROMPT="You are the autonomous development agent for AdventureForge, a strictly typed, headless, deterministic text-adventure engine.

YOUR WORKSPACE IS IN: /home/michael_crosato/projects/zork-unlimited-2
DO NOT work in any temporary or scratch folders outside this directory. All work must be applied directly to this codebase.

CRITICAL: You are executed as a single, discrete cycle within an outer bash loop. You MUST NOT loop indefinitely, run sleep statements, or leave blocking background tasks running. Instead, perform exactly ONE execution cycle of Plan, Build, Verify, Playtest, and Evaluate, write your report, and exit cleanly so the outer loop can capture your work and launch the next cycle.

Core loop for this cycle:

1. PLAN
   * Inspect the current project files and the persistent plan in 'living_plan.md'.
   * Identify the highest-impact next task in the backlog.
   * Prioritize concrete game improvements and resolving real code/pack validation issues.

2. BUILD
   * Implement the selected feature, fix, test, or content expansion.
   * Keep changes scoped to what can be fully verified in this single cycle.
   * Keep the game playable at all times; avoid large untested rewrites.

3. VERIFY
   * Run the TypeScript compiler ('pnpm build') to ensure type safety.
   * Run the test suite ('pnpm test') to ensure no regressions are introduced.
   * Run the content autopilot validator ('pnpm autopilot') to check all game packs.

4. PLAYTEST & EVALUATE
   * Review the auto-playtest outcomes and validation reports generated by your tests and autopilot commands.
   * If any compiler error, test failure, or graph validator warning is reported, fix the issue immediately in this cycle! Do not commit broken code or warnings.

5. RECORD & EXIT
   * Update the 'living_plan.md' file with the latest cycle index, updated task status, learnings, and next priority items.
   * Output a summary matching the exact format below, and then exit the session immediately.

Output format for each cycle:

## Current Plan

* Main objective:
* Why this matters:
* Tasks:
* Risks:

## Work Completed

* Changes made:
* Files/systems touched:
* New content/features added:

## Playtest Notes

* What was tested:
* What worked:
* What felt bad/confusing:
* Bugs found:

## Next Iteration

* Highest-priority next task:
* Reason:
* Planned action:

This is the end of your single cycle. Terminate now."

# Verify execution command or that agy CLI is available
if [[ -z "${AI_AGENT_CMD:-}" ]]; then
  if ! command -v agy &> /dev/null; then
    echo "🔴 Error: The 'agy' (Antigravity) CLI tool could not be found."
    echo "Please make sure it is installed and present in your system PATH, or set AI_AGENT_CMD."
    exit 1
  fi
fi

CYCLE=1
FAILURES=0
MAX_FAILURES=3

echo "================================================================================"
echo "🚀 Starting Indefinite Autonomous AI Developer Loop Harness..."
echo "Press CTRL+C at any time to stop the loop."
echo "================================================================================"

while true; do
  echo ""
  echo "================================================================================"
  echo "🌀 RUNNING AUTONOMOUS CYCLE #$CYCLE"
  echo "================================================================================"
  
  # Run the agent using AI_AGENT_CMD if set, otherwise fallback to agy
  if [[ -n "${AI_AGENT_CMD:-}" ]]; then
    echo "🤖 Executing agent via: $AI_AGENT_CMD"
    echo "$PROMPT" | eval "$AI_AGENT_CMD"
    STATUS=$?
  else
    echo "🤖 Executing agent via 'agy'..."
    agy --dangerously-skip-permissions --print "$PROMPT"
    STATUS=$?
  fi
  
  if [ $STATUS -eq 0 ]; then
    FAILURES=0
    echo "🟢 Cycle #$CYCLE executed successfully."
    
    # Autonomous Git staging and commit
    if [[ -n $(git status --porcelain) ]]; then
      echo ""
      echo "💾 Staging and committing cycle #$CYCLE changes autonomously..."
      git add .
      git commit -m "chore(ai-dev): autonomous cycle #$CYCLE improvements"
      echo "🟢 Committed successfully."
    else
      echo ""
      echo "➖ No changes detected in cycle #$CYCLE. Skipping Git commit."
    fi
  else
    FAILURES=$((FAILURES + 1))
    echo "🔴 Cycle #$CYCLE failed with exit code $STATUS. (Failure $FAILURES of $MAX_FAILURES)"
    
    if [ $FAILURES -ge $MAX_FAILURES ]; then
      echo ""
      echo "🛑 CIRCUIT BREAKER TRIGGERED!"
      echo "The autonomous agent has failed consecutively $MAX_FAILURES times."
      echo "Halthing the dev loop to protect tokens and prevent infinite crash loops."
      echo "Please inspect the error logs above and check the current state."
      echo "================================================================================"
      exit $STATUS
    fi
  fi
  
  # End of cycle, increment and sleep
  echo "================================================================================"
  echo "✅ Cycle #$CYCLE complete!"
  CYCLE=$((CYCLE + 1))
  
  echo "Sleeping for 10 seconds before booting next cycle... Press CTRL+C to exit."
  sleep 10
done
